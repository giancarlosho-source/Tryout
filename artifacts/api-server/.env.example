# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use test keys (sk_test_...) locally; switch to live keys in Railway for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the annual Club License ($799/yr)
STRIPE_PRICE_ID=price_...

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cron ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Sent as x-cron-secret header to POST /api/cron/trial-reminders
CRON_SECRET=

# ── Super Admin ───────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=

# ── Optional ──────────────────────────────────────────────────────────────────
# Public URL of this API server — used in email links (defaults to Railway URL if unset)
APP_URL=https://efficient-amazement-production-864a.up.railway.app

# Sentry DSN for error tracking — leave blank to disable
SENTRY_DSN=

# Runtime (set automatically by Railway — do not set manually in production)
PORT=8080
NODE_ENV=development
